---
import axios from "axios";

const user = (await axios.get("https://api.github.com/users/yhyadev")).data;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/bin" href={user.avatar_url} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{user.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@200;400;700;800&display=swap"
      as="style"
      onload="
      this.onload = null; this.rel = 'stylesheet'
      "
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@200;400;700;800&display=swap"
        rel="stylesheet"
        type="text/css"
      />
    </noscript>
  </head>
  <body>
    <slot />
  </body>
</html>
